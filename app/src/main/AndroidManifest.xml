<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/app_logo"
        android:label="@string/app_name"
        android:roundIcon="@drawable/app_logo"
        android:supportsRtl="true"
        android:theme="@style/Theme.Dog_rider_login"
        android:usesCleartextTraffic="true">

        <!-- ACTIVIDADES ORIGINALES (LOGIN Y REGISTRO) -->
        <activity
            android:name=".SolicitarCitaActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="false" />
        <activity
            android:name=".PerfilActivity"
            android:exported="false" />
        <activity
            android:name=".HomeDuenoActivity"
            android:exported="false" />
        <activity
            android:name=".CambiarContrasenaActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="false" />
        <activity
            android:name=".RecuperarContrasenaActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="false" />
        <activity
            android:name=".RegisterActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="false" />

        <!-- Pantalla de Inicio (Splash) -->
        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.App.Starter">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Esta es la actividad de Login -->
        <activity
            android:name=".MainActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="false" />

        <!-- ACTIVIDADES DE LA INTERFAZ PASEADOR -->
        <activity
            android:name=".HomePaseadorActivity"
            android:exported="false" />
        <activity
            android:name=".PaseosActivity"
            android:exported="false" />
        <activity
            android:name=".ChatActivity"
            android:exported="false" />
        <activity
            android:name=".ChatDetalleActivity"
            android:exported="false" />
        <activity
            android:name=".DetalleMascotaActivity"
            android:exported="false" />

        <!-- ACTIVIDADES DE AÑADIR MASCOTA -->
        <activity
            android:name=".AddPetActivity"
            android:exported="false" />

    </application>

</manifest>