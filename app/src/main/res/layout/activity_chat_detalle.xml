<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_autumn">

    <!-- Top Bar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/chatHeader"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/white"
        android:elevation="4dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBackChat"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_revert"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/blue_primary"
            android:contentDescription="Volver" />

        <TextView
            android:id="@+id/tvChatTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chat"
            android:textColor="@color/black"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Lista Mensajes -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvChatMessages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:padding="8dp"
        app:layout_constraintBottom_toTopOf="@+id/quickEmojiBar"
        app:layout_constraintTop_toBottomOf="@id/chatHeader" />

    <!-- Barra de Emojis Rápidos -->
    <HorizontalScrollView
        android:id="@+id/quickEmojiBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#F5EEDA"
        android:paddingVertical="8dp"
        android:scrollbars="none"
        app:layout_constraintBottom_toTopOf="@+id/inputContainer">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <TextView android:id="@+id/emoji1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🐶" android:textSize="24sp" android:layout_marginEnd="16dp" android:clickable="true" android:focusable="true"/>
            <TextView android:id="@+id/emoji2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🐾" android:textSize="24sp" android:layout_marginEnd="16dp" android:clickable="true" android:focusable="true"/>
            <TextView android:id="@+id/emoji3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🦴" android:textSize="24sp" android:layout_marginEnd="16dp" android:clickable="true" android:focusable="true"/>
            <TextView android:id="@+id/emoji4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="❤️" android:textSize="24sp" android:layout_marginEnd="16dp" android:clickable="true" android:focusable="true"/>
            <TextView android:id="@+id/emoji5" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🐕" android:textSize="24sp" android:layout_marginEnd="16dp" android:clickable="true" android:focusable="true"/>
            <TextView android:id="@+id/quickMsg1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="¡Ya voy!" android:background="@drawable/bubble_other" android:padding="8dp" android:textSize="12sp" android:layout_marginEnd="12dp" android:clickable="true" android:focusable="true"/>
            <TextView android:id="@+id/quickMsg2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="¿Todo bien?" android:background="@drawable/bubble_other" android:padding="8dp" android:textSize="12sp" android:clickable="true" android:focusable="true"/>
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Input -->
    <LinearLayout
        android:id="@+id/inputContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:elevation="8dp"
        android:orientation="horizontal"
        android:padding="8dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <EditText
            android:id="@+id/etChatMessage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/edit_text_background"
            android:hint="Escribe un mensaje..."
            android:padding="12dp"
            android:maxLines="4"
            android:inputType="textCapSentences|textMultiLine" />

        <ImageButton
            android:id="@+id/btnSendMessage"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/button_background"
            android:src="@android:drawable/ic_menu_send"
            app:tint="@color/static_white"
            android:contentDescription="Enviar" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
