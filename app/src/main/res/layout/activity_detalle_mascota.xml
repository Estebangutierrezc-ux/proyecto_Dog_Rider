<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- VOLVER -->
        <Button
            android:id="@+id/backButton"
            android:layout_width="55dp"
            android:layout_height="55dp"
            android:text="←"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:backgroundTint="@color/blue_primary"/>

        <!-- FOTO -->
        <ImageView
            android:id="@+id/dogImage"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_gravity="center"
            android:layout_marginTop="24dp"
            android:src="@drawable/rocky"
            android:scaleType="centerCrop"/>

        <!-- NOMBRE -->
        <TextView
            android:id="@+id/dogName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rocky"
            android:textSize="32sp"
            android:textColor="@color/black"
            android:textStyle="bold"
            android:layout_marginTop="24dp"/>

        <!-- INFO -->
        <TextView
            android:id="@+id/dogBreed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🐶 Raza:"
            android:textSize="18sp"
            android:textColor="@color/black"
            android:layout_marginTop="16dp"/>

        <TextView
            android:id="@+id/dogAge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎂 Edad:"
            android:textSize="18sp"
            android:textColor="@color/black"
            android:layout_marginTop="8dp"/>

        <TextView
            android:id="@+id/dogPersonality"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="😎 Personalidad:"
            android:textSize="18sp"
            android:textColor="@color/black"
            android:layout_marginTop="8dp"/>

        <TextView
            android:id="@+id/dogHour"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🕒 Paseo:"
            android:textSize="18sp"
            android:textColor="@color/blue_primary"
            android:textStyle="bold"
            android:layout_marginTop="8dp"/>

        <!-- VALOR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/white"
            android:elevation="2dp"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginTop="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💵 Valor del paseo"
                android:textSize="18sp"
                android:textColor="@color/light_gray"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/dogPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$0"
                android:textSize="32sp"
                android:textColor="@color/blue_primary"
                android:textStyle="bold"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <!-- BOTONES -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="32dp">

            <!-- INICIAR -->
            <Button
                android:id="@+id/startWalkButton"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="INICIAR PASEO"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:backgroundTint="@color/blue_primary"/>

            <Space
                android:layout_width="12dp"
                android:layout_height="match_parent"/>

            <!-- COBRAR -->
            <Button
                android:id="@+id/payButton"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="COBRAR"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:backgroundTint="#4CAF50"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
