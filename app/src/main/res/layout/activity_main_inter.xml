<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- CONTENIDO -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- HEADER -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="¡Hola, paseador! 👋"
                        android:textSize="28sp"
                        android:textColor="@color/blue_primary"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Listo para más aventuras hoy"
                        android:textSize="16sp"
                        android:textColor="@color/light_gray"/>
                </LinearLayout>

                <!-- CAMPANA -->
                <FrameLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_alignParentEnd="true">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="center"
                        android:src="@android:drawable/ic_popup_reminder"
                        app:tint="@color/light_gray"/>

                    <View
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="#FF3B30"
                        android:layout_gravity="top|end"
                        android:layout_marginTop="8dp"
                        android:layout_marginEnd="8dp"/>
                </FrameLayout>
            </RelativeLayout>

            <!-- TITULO -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PASEO ACTIVO"
                android:textSize="18sp"
                android:textColor="@color/blue_primary"
                android:textStyle="bold"
                android:layout_marginTop="32dp"/>

            <!-- CARD PASEO ACTIVO -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/white"
                android:elevation="2dp"
                android:padding="16dp"
                android:layout_marginTop="12dp">

                <!-- INFO PERRO -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:id="@+id/dogImage"
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:src="@drawable/rocky"
                        android:scaleType="centerCrop"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_toEndOf="@id/dogImage"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:id="@+id/dogName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rocky"
                            android:textSize="24sp"
                            android:textColor="@color/black"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/dogBreed"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Bulldog • 4 años"
                            android:textColor="@color/light_gray"
                            android:textSize="16sp"/>

                        <TextView
                            android:id="@+id/dogHour"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🕒 03:00 PM"
                            android:textColor="@color/blue_primary"
                            android:textSize="16sp"/>
                    </LinearLayout>
                </RelativeLayout>

                <!-- BOTONES -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp">

                    <Button
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:text="INICIAR PASEO"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:backgroundTint="@color/blue_primary"/>

                    <Space
                        android:layout_width="12dp"
                        android:layout_height="match_parent"/>

                    <Button
                        android:id="@+id/gpsButton"
                        android:layout_width="64dp"
                        android:layout_height="56dp"
                        android:text="📍"
                        android:textSize="20sp"
                        android:backgroundTint="@color/light_gray"/>
                </LinearLayout>

                <!-- GPS STATUS -->
                <TextView
                    android:id="@+id/gpsStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="❌ GPS desconectado"
                    android:textSize="14sp"
                    android:textColor="@color/red_error"
                    android:layout_marginTop="12dp"/>
            </LinearLayout>

            <!-- TARJETAS SECUNDARIAS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="24dp">

                <!-- RESEÑAS -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:background="@color/white"
                    android:elevation="2dp"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⭐"
                        android:textSize="28sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mis reseñas"
                        android:textColor="@color/black"
                        android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>

            <!-- RESUMEN -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Resumen de hoy"
                android:textSize="22sp"
                android:textColor="@color/blue_primary"
                android:textStyle="bold"
                android:layout_marginTop="32dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/white"
                android:elevation="2dp"
                android:orientation="horizontal"
                android:padding="20dp"
                android:layout_marginTop="12dp">

                <!-- PASEOS -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="3"
                        android:textSize="32sp"
                        android:textColor="@color/black"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Paseos"
                        android:textColor="@color/light_gray"/>
                </LinearLayout>

                <!-- GANANCIAS -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$28k"
                        android:textSize="32sp"
                        android:textColor="@color/blue_primary"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ganancias"
                        android:textColor="@color/light_gray"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- BOTTOM NAVIGATION -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="@color/white"
        android:elevation="8dp"
        android:orientation="horizontal"
        android:gravity="center">

        <!-- HOME -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏠"
                android:textSize="24sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                android:textColor="@color/blue_primary"
                android:textStyle="bold"
                android:textSize="12sp"/>
        </LinearLayout>

        <!-- PASEOS -->
        <LinearLayout
            android:id="@+id/btnPaseos"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🐕"
                android:textSize="24sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Paseos"
                android:textColor="@color/light_gray"
                android:textSize="12sp"/>
        </LinearLayout>

        <!-- CHAT -->
        <LinearLayout
            android:id="@+id/btnChat"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💬"
                android:textSize="24sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chat"
                android:textColor="@color/light_gray"
                android:textSize="12sp"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
