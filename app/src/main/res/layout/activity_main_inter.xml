<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- CONTENIDO -->

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- HEADER -->

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="¡Hola, paseador! 👋"
                        android:textSize="34sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Listo para más aventuras hoy"
                        android:textSize="18sp"
                        android:textColor="#777777"/>

                </LinearLayout>

                <!-- CAMPANA -->

                <FrameLayout
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_alignParentEnd="true">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="center"
                        android:src="@android:drawable/ic_dialog_info"/>

                    <View
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:background="#FF3B30"
                        android:layout_gravity="top|end"/>

                </FrameLayout>

            </RelativeLayout>

            <!-- TITULO -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PASEO ACTIVO"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginTop="30dp"/>

            <!-- CARD -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#F0F2F6"
                android:padding="18dp"
                android:layout_marginTop="14dp">

                <!-- INFO PERRO -->

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:id="@+id/dogImage"
                        android:layout_width="110dp"
                        android:layout_height="110dp"
                        android:src="@drawable/rocky"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_toEndOf="@id/dogImage"
                        android:layout_marginStart="18dp">

                        <!-- NOMBRE -->

                        <TextView
                            android:id="@+id/dogName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rocky"
                            android:textSize="30sp"
                            android:textStyle="bold"/>

                        <!-- RAZA -->

                        <TextView
                            android:id="@+id/dogBreed"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Bulldog • 4 años"
                            android:textSize="18sp"/>

                        <!-- HORA -->

                        <TextView
                            android:id="@+id/dogHour"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🕒 03:00 PM"
                            android:textSize="18sp"/>

                    </LinearLayout>

                </RelativeLayout>

                <!-- BOTONES -->

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="20dp">

                    <Button
                        android:layout_width="0dp"
                        android:layout_height="60dp"
                        android:layout_weight="1"
                        android:text="INICIAR PASEO"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#000000"/>

                    <Space
                        android:layout_width="12dp"
                        android:layout_height="match_parent"/>

                    <Button
                        android:id="@+id/gpsButton"
                        android:layout_width="70dp"
                        android:layout_height="60dp"
                        android:text="📍"
                        android:textSize="24sp"
                        android:backgroundTint="#000000"/>

                </LinearLayout>

                <!-- GPS -->

                <TextView
                    android:id="@+id/gpsStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="❌ GPS desconectado"
                    android:textSize="18sp"
                    android:textColor="#FF0000"
                    android:layout_marginTop="18dp"/>

            </LinearLayout>

            <!-- TARJETAS -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="25dp">

                <!-- RESEÑAS -->

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="110dp"
                    android:layout_weight="1"
                    android:background="#FFF8E7"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⭐"
                        android:textSize="30sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mis reseñas"
                        android:textStyle="bold"/>

                </LinearLayout>

                <!-- GANANCIAS -->

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="110dp"
                    android:layout_weight="1"
                    android:background="#EEFFF1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💵"
                        android:textSize="30sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ganancias"
                        android:textStyle="bold"/>

                </LinearLayout>

            </LinearLayout>

            <!-- RESUMEN -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Resumen de hoy"
                android:textSize="26sp"
                android:textStyle="bold"
                android:layout_marginTop="30dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:orientation="horizontal"
                android:padding="20dp"
                android:layout_marginTop="16dp">

                <!-- PASEOS -->

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="3"
                        android:textSize="34sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Paseos"/>

                </LinearLayout>

                <!-- GANANCIAS -->

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$28k"
                        android:textSize="34sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ganancias"/>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- BOTTOM NAVIGATION -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="75dp"
        android:background="#FFFFFF"
        android:orientation="horizontal"
        android:gravity="center">

        <!-- HOME -->

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏠"
                android:textSize="24sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                android:textStyle="bold"/>

        </LinearLayout>

        <!-- PASEOS -->

        <LinearLayout
            android:id="@+id/btnPaseos"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🐕"
                android:textSize="24sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Paseos"/>

        </LinearLayout>

        <!-- CHAT -->

        <LinearLayout
            android:id="@+id/btnChat"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💬"
                android:textSize="24sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chat"/>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>